# Prediction Market Trading Bot — Environment Variables
# Copy to .env and fill in your keys. All are optional for paper trading.

# Kalshi (for future live trading — not needed for paper mode)
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=

# AI Models (optional — heuristic fallback available without these)
ANTHROPIC_API_KEY=

# Research Sources (optional — Google News RSS works without keys)
NEWS_API_KEY=
